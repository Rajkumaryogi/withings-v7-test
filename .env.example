# AWS / DynamoDB (tokens: vitals-di-tokens, vitals: user_vitals)
AWS_REGION=us-east-1

# OAuth redirect (must match Withings Developer Portal). Overrides config.json when set.
# WITHINGS_REDIRECT_URI=https://withings-v7-test.onrender.com/callback
TOKENS_TABLE=vitals-di-tokens
USER_VITALS_TABLE=user_vitals

# Public webhook (required for Withings push → user_vitals auto-sync)
# WITHINGS_WEBHOOK_URL=https://your-host.example.com/webhook/withings
# Or set origin only:
# PUBLIC_WEBHOOK_BASE_URL=https://your-host.example.com

# Optional: override notify subscribe POST URL. Must end with /v2/notify — NOT the bare host (that causes status 2554).
# WITHINGS_NOTIFY_API_URL=https://wbsapi.withings.net/v2/notify

# Optional: comma-separated appli ids for subscribe (default: 1,2,4,16,44,50,51)
# WITHINGS_NOTIFY_APPLIS=1,2,4,16,44

# CLI sync fallback
# COGNITO_USER_ID=

# Realtime gateway (optional)
# VITALS_REALTIME_GATEWAY_URL=
# VITALS_REALTIME_GATEWAY_SECRET=
